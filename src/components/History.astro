---
import { config } from '../config';

const { history, storesInfo, general } = config;
---

<!-- OWNER STORY + HISTORY — Emotional Connection Block -->
<section id="historia" class="relative overflow-hidden">
  <!-- PART 1: Owner Storytelling — Full Width Emotional Block -->
  <div class="relative py-20 md:py-32 bg-gray-900 overflow-hidden text-white">
    <!-- Clean Dark Background (No overpowering gradients for a more premium look) -->
    
    <div class="container mx-auto px-6 md:px-12">
    <!-- Section Header border-brand-primary/20 text-brand-primary bg-brand-primary/10 -->
    <div class="text-center mb-16 md:mb-24 aos-fade-up">
      <span class="inline-block px-4 py-2 border border-brand-primary/30 rounded-full font-black uppercase tracking-[0.3em] text-[10px] text-brand-primary mb-6 shadow-sm">{history.pillText}</span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-display tracking-tight leading-[1.1] max-w-2xl mx-auto text-white">
        {history.headlineStart} <span class="text-brand-primary block mt-1">{history.headlineHighlight}</span>
      </h2>
    </div>

    <!-- Layout Container: Vertical Stack as requested -->
    <div class="flex flex-col items-center max-w-4xl mx-auto gap-12 md:gap-16">
      
      <!-- Center: Image -->
      <div class="w-full relative justify-center flex aos-zoom-in">
          <div class="w-full max-w-xl h-[28rem] md:h-[36rem] rounded-[2.5rem] overflow-hidden shadow-2xl bg-white/5 border border-white/10 relative transform hover:scale-[1.02] transition-transform duration-500">
            <img 
              src={history.ownerImage} 
              alt="Fundador"
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="lazy"
            />
          </div>
        </div>

      <!-- Below: Emotional Text Block -->
      <div class="w-full max-w-3xl text-center aos-fade-up z-20">
        <div class="space-y-6 text-white/80 text-[16px] md:text-xl font-medium leading-relaxed bg-white/5 backdrop-blur-sm border border-white/10 p-8 md:p-10 rounded-[2rem]">
          {history.paragraphs.map(p => (
            <p set:html={p}></p>
          ))}
        </div>
      </div>

      <!-- Bottom: Stats Block -->
      <div class="w-full rounded-[2.5rem] bg-white/5 border border-brand-primary/20 p-8 md:p-12 relative overflow-hidden aos-fade-up">
          <div class="flex flex-col md:flex-row items-center justify-around gap-10 md:gap-6 relative overflow-hidden group">
            <!-- decorative background in stats -->
            <div class="absolute inset-0 bg-brand-primary/5 group-hover:bg-brand-primary/10 transition-colors duration-500"></div>
            
            {history.stats.map(stat => (
              <div class="flex flex-col items-center text-center gap-2 relative z-10 w-full md:w-1/3">
                <span class={`text-5xl md:text-6xl font-black ${stat.highlightColor}`}>{stat.number}</span>
                <span class="text-[11px] md:text-[13px] uppercase font-bold tracking-widest text-white/70 leading-tight">
                  {stat.labelLines[0]}<br/>{stat.labelLines[1]}
                </span>
              </div>
            ))}
          </div>

          <!-- CTA inside stats area or below -->
          <div class="mt-10 flex justify-center w-full">
            <a 
              href={`https://wa.me/${general.whatsappNumber}?text=${encodeURIComponent(history.ctaMessage)}`}
              target="_blank"
              class="btn-whatsapp inline-flex items-center gap-3 px-8 md:px-10 py-5 text-sm md:text-base w-full sm:w-auto justify-center shadow-2xl"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.81 11.81 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413z"/>
              </svg>
              <span class="font-black pt-0.5">{history.ctaText}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- PART 2: Store Locations — Clean Cards + Images -->
  <div class="py-24 md:py-32 bg-brand-beige">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 aos-fade-up">
        <span class="inline-block px-4 py-2 border border-brand-primary/30 rounded-full font-black uppercase tracking-[0.3em] text-[10px] text-brand-primary mb-6 bg-white/50">{storesInfo.pillText}</span>
        <h2 class="text-4xl md:text-5xl font-display mb-6 tracking-tight">{storesInfo.headlineStart} <span class="text-brand-primary">{storesInfo.headlineHighlight}</span></h2>
        <p class="text-gray-500 text-lg md:text-xl font-medium max-w-xl mx-auto">{storesInfo.subheadline}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 max-w-5xl mx-auto">
        {storesInfo.stores.map((store, index) => (
          <div class="card-premium relative overflow-hidden group hover:border-brand-primary/30 flex flex-col h-full bg-white shadow-[0_20px_50px_rgba(0,0,0,0.06)] p-0 rounded-3xl md:rounded-[2.5rem] aos-fade-up" style={`animation-delay: ${index * 0.2}s`}>
            
            <!-- Store Image -->
            <div class="w-full h-56 md:h-64 overflow-hidden relative">
              <img src={store.image} alt={store.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <!-- Badge overlay -->
              <div class="absolute top-4 right-4 bg-white/95 backdrop-blur-md px-4 py-1.5 rounded-full shadow-lg">
                <span class="text-[10px] font-black uppercase tracking-widest text-brand-primary">Unidade {index + 1}</span>
              </div>
            </div>

            <!-- Content -->
            <div class="p-8 md:p-10 flex flex-col grow">
              <h3 class="text-2xl md:text-3xl font-display mb-6 text-gray-900">{store.name}</h3>
              
              <!-- Contact Details Grid -->
              <div class="grid grid-cols-1 gap-4 mb-8">
                <div class="flex items-start gap-4">
                  <div class="bg-brand-primary/10 p-3 rounded-full shrink-0 text-brand-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  </div>
                  <div class="flex flex-col pt-1">
                    <span class="text-xs uppercase font-bold text-gray-400 tracking-wider mb-1">Endereço</span>
                    <span class="text-gray-900 font-medium">{store.address} - {store.city}</span>
                  </div>
                </div>
                
                <div class="flex items-start gap-4">
                  <div class="bg-brand-primary/10 p-3 rounded-full shrink-0 text-brand-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  </div>
                  <div class="flex flex-col pt-1">
                    <span class="text-xs uppercase font-bold text-gray-400 tracking-wider mb-1">Telefone</span>
                    <a href={`tel:${store.phone.replace(/\D/g, '')}`} class="text-gray-900 font-black text-lg hover:text-brand-primary transition-colors">{store.phone}</a>
                  </div>
                </div>
              </div>

              <!-- Map Button -->
              <div class="mt-auto pt-4 border-t border-gray-100">
                <a href={store.map} target="_blank" class="w-full flex items-center justify-center gap-3 text-sm font-black uppercase tracking-widest text-brand-primary group-hover:bg-brand-primary group-hover:text-white transition-all duration-300 border-2 border-brand-primary/20 rounded-full px-8 py-4 bg-white shadow-sm hover:shadow-lg">
                  VER NO MAPA
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="translate-y-px"><path d="m12 5 7 7-7 7"/><path d="M5 12h14"/></svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
