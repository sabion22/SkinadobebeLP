---
import { config } from '../config';

const { vsl } = config;
---

<!-- VSL SECTION -->
<section id="vsl" class="relative py-12 md:py-16 bg-white overflow-hidden">
  <div class="container mx-auto px-6 md:px-12">

    <!-- Section Header -->
    <div class="text-center mb-10 md:mb-12 aos-fade-up">
      <span class="inline-flex items-center gap-2 px-4 py-2 text-[10px] sm:text-xs font-black tracking-[0.25em] text-brand-primary uppercase bg-white rounded-full border border-brand-primary/20 mb-6 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
        {vsl.pillText}
      </span>
      <h2 class="flex flex-col items-center justify-center font-display mb-4 tracking-tight">
        <span class="text-2xl md:text-4xl text-gray-500 font-medium tracking-wide mb-1">{vsl.headlineLine1}</span>
        <span class="text-4xl md:text-6xl lg:text-7xl font-bold text-brand-primary italic leading-none text-center drop-shadow-sm">{vsl.headlineLine2}</span>
      </h2>
      <p class="text-gray-500 text-base md:text-xl max-w-2xl mx-auto font-medium">
        {vsl.subheadline}
      </p>
    </div>

    <!-- Video / Poster Container -->
    <div class="relative mx-auto max-w-2xl aos-fade-up" style="animation-delay: 0.2s;">
      <div
        id="vsl-wrapper"
        class={`relative rounded-3xl md:rounded-[2.5rem] overflow-hidden shadow-[0_30px_80px_rgba(217,20,121,0.15)] border-4 md:border-8 border-white ${vsl.videoAspectRatio} ${vsl.videoMaxHeightDesktop} bg-gray-900 mx-auto w-full max-w-[90vw] md:max-w-4xl lg:max-w-5xl`}
      >
        {vsl.usePosterFallback ? (
          /* ── PLACEHOLDER MODE (sem vídeo ainda) ── */
          <div class="absolute inset-0 flex items-center justify-center">
            {/* Imagem de fundo */}
            <img
              src={vsl.posterSrc}
              alt="Vídeo Skina do Bebê — em breve"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            {/* Overlay */}
            <div class="absolute inset-0 bg-brand-primary/60 backdrop-blur-[3px]"></div>
            {/* Conteúdo central */}
            <div class="relative z-10 flex flex-col items-center gap-5 px-8 text-center">
              <div class="w-20 h-20 md:w-24 md:h-24 bg-white rounded-full flex items-center justify-center shadow-2xl">
                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary ml-1" aria-hidden="true">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
              </div>
              <div>
                <p class="text-white font-display text-xl md:text-2xl font-bold mb-1 drop-shadow-lg">
                  Vídeo em breve
                </p>
                <p class="text-white/75 text-xs md:text-sm font-medium uppercase tracking-widest">
                  Conteúdo sendo produzido
                </p>
              </div>
            </div>
          </div>
        ) : (
          /* ── PLAYER MODE (vídeo disponível no youtube com overlay customizado) ── */
          <>
            <div id="vsl-poster-container" data-video={vsl.videoSrc} class="absolute inset-0 z-10 flex items-center justify-center cursor-pointer group">
              {/* Imagem de fundo */}
              <img
                src={vsl.posterSrc}
                alt="Vídeo Skina do Bebê"
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
              {/* Overlay */}
              <div class="absolute inset-0 bg-brand-primary/40 backdrop-blur-[1px] group-hover:bg-brand-primary/30 transition-colors"></div>
              {/* Botão de Play Customizado */}
              <div class="relative z-20 w-24 h-24 md:w-32 md:h-32 bg-white/95 backdrop-blur-md rounded-full flex items-center justify-center shadow-2xl transition-all duration-500 group-hover:scale-110 text-brand-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="currentColor" class="translate-x-1" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>

            <!-- O Iframe será injetado aqui via JS apenas após o clique -->
            <div id="vsl-iframe-container" class="absolute inset-0 w-full h-full z-0"></div>
          </>
        )}
      </div>
    </div>

  </div>
</section>

<script>
  function initVsl() {
    const poster = document.getElementById('vsl-poster-container');
    const container = document.getElementById('vsl-iframe-container');

    // Se não encontrou, ou se já inicializou, cancela
    if (!poster || !container || poster.dataset.initialized) return;
    
    poster.dataset.initialized = "true";

    poster.addEventListener('click', () => {
      const videoSrc = poster.dataset.video || '';
      
      // Formata a URL do YouTube para embutir com autoplay imediato
      let embedUrl = videoSrc;
      if (videoSrc.includes('youtu')) {
        const videoId = videoSrc.split('youtu.be/')[1]?.split('?')[0] || videoSrc.split('v=')[1]?.split('&')[0];
        embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=0&playsinline=1&rel=0&modestbranding=1&controls=1`;
      }
      
      // Injeta o iframe
      container.innerHTML = `<iframe id="youtube-iframe" src="${embedUrl}" title="Video Skina do Bebe" class="absolute inset-0 w-full h-full border-0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
      
      // Esconde o poster
      poster.style.display = 'none';

      // Dispara o modo Tela Cheia usando a permissão do clique do usuário
      // Um pequeno timeout garante que o navegador já renderizou o iframe no DOM
      setTimeout(() => {
        const iframe = document.getElementById('youtube-iframe') as any;
        if (iframe) {
          try {
            if (iframe.requestFullscreen) {
              iframe.requestFullscreen();
            } else if (iframe.webkitRequestFullscreen) { /* Safari / iOS */
              iframe.webkitRequestFullscreen();
            } else if (iframe.msRequestFullscreen) { /* IE/Edge antigo */
              iframe.msRequestFullscreen();
            }
          } catch (e) {
            console.warn("Navegador bloqueou tela cheia automática", e);
          }
        }
      }, 50);
    });
  }

  // Tenta rodar imediatamente caso o DOM já esteja pronto
  initVsl();
  // Caso não esteja pronto, garante a execução no carregamento
  document.addEventListener('DOMContentLoaded', initVsl);
</script>
