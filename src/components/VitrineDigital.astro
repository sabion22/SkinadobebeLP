---
import { config } from '../config';

const { destaques, general } = config;
const WA = general.whatsappNumber;

// Resolve o array de imagens por produto
type Product = (typeof destaques.products)[0];
function getImages(product: Product): string[] {
  return product.images && product.images.length > 0 ? product.images : [];
}
---

<!-- DESTAQUES DA SEMANA -->
<section id="destaques" class="relative py-16 md:py-24">

  <!-- Background (overflow:hidden isolado para não bloquear scroll dos produtos) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-warm via-white to-brand-beige"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-promo-yellow/5 rounded-full blur-[150px] -translate-y-1/3 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-brand-primary/7 rounded-full blur-[130px] translate-y-1/3 -translate-x-1/3"></div>
    <div class="absolute top-0 inset-x-0 h-[3px] bg-gradient-to-r from-promo-red via-promo-orange to-promo-yellow"></div>
  </div>

  <div class="container mx-auto px-6 md:px-12 relative z-10">

    <!-- HEADER: título esquerda / timer direita -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 mb-10 md:mb-14 items-center aos-fade-up">

      <!-- Esquerda: Título -->
      <div class="text-center lg:text-left">
        <span class="inline-flex items-center gap-2 px-4 py-2 text-[10px] font-black tracking-[0.25em] uppercase rounded-full mb-5 badge-hot shadow-md">
          {destaques.pillText}
        </span>
        <h2 class="text-4xl md:text-5xl font-display mb-4 tracking-tight text-gray-900 leading-[1.08]">
          {destaques.headlineStart}&nbsp;<span class="text-promo-red">{destaques.headlineHighlight}</span>
        </h2>
        <p class="text-gray-500 text-base md:text-lg font-medium leading-relaxed max-w-lg mx-auto lg:mx-0">
          {destaques.subheadlineStart} <strong class="text-gray-800">{destaques.subheadlineBold1}</strong>
          {" "}{destaques.subheadlineMiddle}{" "}
          <strong class="text-promo-red">{destaques.subheadlineBold2}</strong>{destaques.subheadlineEnd}
        </p>
      </div>

      <!-- Direita: Timer elegante -->
      {destaques.showTimer && (
        <div class="flex justify-center lg:justify-end">
          <div class="bg-white/60 backdrop-blur-lg rounded-[2rem] border border-white p-6 sm:p-7 flex flex-col sm:flex-row items-center gap-5 sm:gap-8 shadow-[0_15px_40px_rgba(0,0,0,0.05)] w-fit max-w-full" role="timer" aria-label="Contador das ofertas">
            <div class="flex flex-col items-center sm:items-start flex-shrink-0">
               <span class="text-[9px] font-black tracking-[0.25em] uppercase text-brand-primary mb-2">Oferta Especial</span>
               <span class="text-gray-900 font-display font-bold text-base sm:text-xl leading-snug text-center sm:text-left whitespace-nowrap sm:whitespace-normal max-w-full sm:max-w-[160px]">{destaques.timerText}</span>
            </div>
            
            <div id="countdown-timer" class="flex items-center justify-between w-full sm:w-auto sm:justify-start gap-1 sm:gap-2 shrink-0" data-end={destaques.timerEndDate}>
              <div class="flex flex-col items-center justify-center p-2 min-w-[3.5rem]">
                <span id="days" class="font-display font-light text-4xl text-gray-800 tracking-tighter">00</span>
                <span class="text-[9px] uppercase tracking-widest text-gray-400 font-bold mt-1">Dias</span>
              </div>
              <span class="text-2xl text-gray-300 font-light pb-4">:</span>
              <div class="flex flex-col items-center justify-center p-2 min-w-[3.5rem]">
                <span id="hours" class="font-display font-light text-4xl text-gray-800 tracking-tighter">00</span>
                <span class="text-[9px] uppercase tracking-widest text-gray-400 font-bold mt-1">Hrs</span>
              </div>
              <span class="text-2xl text-gray-300 font-light pb-4">:</span>
              <div class="flex flex-col items-center justify-center p-2 min-w-[3.5rem]">
                <span id="minutes" class="font-display font-light text-4xl text-brand-primary tracking-tighter font-medium">00</span>
                <span class="text-[9px] uppercase tracking-[0.2em] text-brand-primary/60 font-bold mt-1">Min</span>
              </div>
              <span class="text-2xl text-gray-300 font-light pb-4">:</span>
              <div class="flex flex-col items-center justify-center p-2 min-w-[3.5rem]">
                <span id="seconds" class="font-display font-light text-4xl text-brand-primary tracking-tighter font-medium">00</span>
                <span class="text-[9px] uppercase tracking-[0.2em] text-brand-primary/60 font-bold mt-1">Seg</span>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>

    <div
      id="products-scroll"
      class="overflow-x-auto md:overflow-visible -mx-6 px-6 md:mx-0 md:px-0 py-6 md:py-4"
    >
      <div class="products-flex flex flex-nowrap w-max md:w-auto md:grid md:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
        {destaques.products.map((product) => {
          const imgs = getImages(product);
          const waLink = `https://wa.me/${WA}?text=${encodeURIComponent(product.whatsappMessage)}`;
          const carouselId = `carousel-${product.id}`;
          return (
            <div
              class={`product-card shrink-0 w-[76vw] sm:w-72 md:w-auto group flex flex-col relative ${product.isHighlighted ? 'scale-[1.02] md:scale-105 z-10' : ''}`}
              data-total={imgs.length}
            >
              <!-- Carrossel de fotos do produto -->
              <div
                id={carouselId}
                class={`product-photo-carousel relative rounded-[1.75rem] overflow-hidden bg-gray-100 shadow-[0_12px_40px_rgba(0,0,0,0.07)] ${product.isHighlighted ? 'border-[3px] border-brand-primary shadow-[0_15px_40px_rgba(217,20,121,0.25)] ring-4 ring-brand-primary/10' : ''}`}
                style="aspect-ratio:4/5;"
                data-carousel
              >
                <!-- Track -->
                <div class="photo-track absolute inset-0 flex"
                  style="width:100%; transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);">
                  {imgs.map((img, i) => (
                    <img
                      src={img}
                      alt={`${product.name} — foto ${i + 1}`}
                      class="shrink-0 object-cover"
                      style="width:100%;height:100%;flex-shrink:0;"
                    />
                  ))}
                </div>

                <!-- Dots (só quando há múltiplas imagens) -->
                {imgs.length > 1 && (
                  <div class="photo-dots-row absolute bottom-3 inset-x-0 flex justify-center gap-1.5 z-10 pointer-events-none">
                    {imgs.map((_, i) => (
                      <span
                        class={`photo-dot w-2 h-2 rounded-full bg-white transition-opacity duration-300 ${i === 0 ? 'opacity-100' : 'opacity-35'}`}
                      ></span>
                    ))}
                  </div>
                )}

                <!-- Desktop hover: QUERO ESSE! -->
                <div class="hover-overlay absolute inset-0 bg-gradient-to-t from-gray-950/90 via-gray-900/20 to-transparent opacity-0 md:group-hover:opacity-100 transition-opacity duration-400 flex items-end p-5">
                  <a
                    href={waLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full btn-whatsapp py-3.5 text-xs font-black tracking-widest uppercase hidden md:flex"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.81 11.81 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413z"/></svg>
                    {product.whatsappCtaText}
                  </a>
                </div>
              </div>

              <!-- Info abaixo da foto -->
              <div class="mt-4 px-0.5 flex flex-col flex-1">
                <!-- Badge acima do título -->
                <span class={`${product.badgeClass} badge-promo self-start mb-2 text-[9px]`}>
                  {product.badge}
                </span>
                <h3 class="text-lg md:text-xl font-display text-gray-900 group-hover:text-brand-primary transition-colors duration-300 mb-1.5 leading-tight">
                  {product.name}
                </h3>
                <p class="text-gray-400 text-[12px] md:text-sm leading-relaxed line-clamp-2">
                  {product.description}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- CTA ÚNICO abaixo dos produtos -->
    <div class="mt-10 md:mt-14 flex justify-center aos-fade-up">
      <a
        href={`https://wa.me/${WA}?text=${encodeURIComponent(destaques.ctaMessage)}`}
        target="_blank"
        rel="noopener noreferrer"
        id="destaques-cta"
        class="btn-whatsapp flex items-center justify-center gap-3 px-10 md:px-16 py-4 md:py-5 text-sm md:text-base font-black tracking-wide animate-pulse-glow w-full sm:w-auto text-center"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.81 11.81 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413z"/></svg>
        <span>{destaques.ctaText}</span>
      </a>
    </div>

  </div>
</section>

<style>
  /* ── MOBILE SCROLL ── */
  @media (max-width: 767px) {
    #products-scroll {
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    #products-scroll::-webkit-scrollbar { display: none; }
  }
</style>

<script>
  // ── TIMER ──────────────────────────────────────────────
  (function initTimer() {
    const el = document.getElementById('countdown-timer');
    if (!el) return;
    const timerEl = el as HTMLElement;
    const endMs = new Date(timerEl.getAttribute('data-end') || '').getTime();
    if (isNaN(endMs)) return;

    function pad(n: number) { return String(n).padStart(2, '0'); }
    function tick() {
      const dist = endMs - Date.now();
      if (dist < 0) {
        timerEl.innerHTML = '<div class="w-full text-center py-2"><span style="color:#d91479;font-weight:900;font-size:1.1rem;letter-spacing:0.1em;text-transform:uppercase;">Oferta Encerrada</span><br/><span style="font-size:0.75rem;color:#888;">Fale com uma consultora para novas ofertas</span></div>';
        timerEl.classList.remove('justify-start');
        timerEl.classList.add('justify-center');
        return;
      }
      const d = Math.floor(dist / 86400000);
      const h = Math.floor((dist % 86400000) / 3600000);
      const m = Math.floor((dist % 3600000) / 60000);
      const s = Math.floor((dist % 60000) / 1000);
      const eDays = document.getElementById('days');    if (eDays) eDays.textContent = pad(d);
      const eHrs  = document.getElementById('hours');   if (eHrs)  eHrs.textContent  = pad(h);
      const eMins = document.getElementById('minutes'); if (eMins) eMins.textContent = pad(m);
      const eSecs = document.getElementById('seconds'); if (eSecs) eSecs.textContent = pad(s);
    }
    tick();
    setInterval(tick, 1000);
  })();

  // ── AUTO-SCROLL CONTÍNUO E INFINITO (mobile only) ─
  function initProductsAutoScroll() {
    const scroller = document.getElementById('products-scroll') as HTMLElement | null;
    const track = scroller?.querySelector('.products-flex') as HTMLElement | null;
    
    // Cancela se não encontrar elementos ou se já foi inicializado
    if (!scroller || !track || scroller.dataset.autoScrollInit) return;
    
    // Só ativa no mobile (largura < 768px)
    if (window.innerWidth >= 768) return;

    scroller.dataset.autoScrollInit = "true";

    // Para o scroll infinito funcionar e ser contínuo, precisamos duplicar as 4 cartas originais.
    const originalHTML = track.innerHTML;
    track.innerHTML = originalHTML + originalHTML;

    // Desativa completamente o snap via JS para garantir que não haja pulos
    scroller.style.scrollSnapType = 'none';

    let reqId: number;
    let touched = false;
    let scrollPos = scroller.scrollLeft;

    function crawl() {
      // Se a largura não estiver calculada, espera
      if (scroller!.scrollWidth <= 0) {
        reqId = requestAnimationFrame(crawl);
        return;
      }

      // A metade exata da largura de rolagem representa o primeiro conjunto
      const halfWidth = scroller!.scrollWidth / 2;

      if (!touched) {
        // Velocidade otimizada para garantir o movimento fluido sem travar em subpixels
        scrollPos += 0.5;
        
        if (scrollPos >= halfWidth) {
          scrollPos -= halfWidth; 
        }
        
        scroller!.scrollLeft = scrollPos;
      } else {
        scrollPos = scroller!.scrollLeft;
        
        if (scrollPos >= halfWidth) {
          scroller!.scrollLeft = scrollPos - halfWidth;
        } else if (scrollPos <= 0) {
          scroller!.scrollLeft = scrollPos + halfWidth;
        }
      }

      reqId = requestAnimationFrame(crawl);
    }
    
    reqId = requestAnimationFrame(crawl);

    scroller.addEventListener('touchstart', () => { touched = true; }, { passive: true });
    scroller.addEventListener('touchend', () => { touched = false; }, { passive: true });
  }

  initProductsAutoScroll();
  document.addEventListener('DOMContentLoaded', initProductsAutoScroll);

  // ── CARROSSEL DE FOTOS POR PRODUTO ──────────────────────
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(carousel => {
    const track = carousel.querySelector<HTMLElement>('.photo-track');
    const dots  = carousel.querySelectorAll<HTMLElement>('.photo-dot');
    if (!track) return;
    const total = track.children.length;
    if (total <= 1) return;

    let current = 0;

    function goTo(idx: number) {
      current = ((idx % total) + total) % total;
      track!.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        d.style.opacity = i === current ? '1' : '0.35';
      });
    }

    let interval = window.setInterval(() => goTo(current + 1), 3000);

    // O usuário pediu que as fotos do produto passem apenas automaticamente, sem controle manual,
    // para que o swipe na tela inteira funcione perfeitamente para a galeria.
    // Nenhuma interação de touch/mouse é necessária aqui.
  });
</script>
