---
import { config } from '../config';

const { footer, general } = config;
const year = new Date().getFullYear();
---

<footer id="contato" class="bg-gray-900 text-white pt-24 pb-16 overflow-hidden relative">
  <!-- Soft light effect -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-brand-primary/50 to-transparent"></div>

  <div class="container mx-auto px-6 md:px-12 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16 mb-24">
      <!-- Brand -->
      <div class="lg:col-span-1 aos-fade-up">
        <div class="flex items-center gap-3 mb-8">
          {general.logoSrc ? (
            <img 
              src={general.logoSrc} 
              alt={general.logoAlt || "Logo"} 
              class="h-10 w-auto object-contain"
            />
          ) : (
            <div class="w-12 h-12 bg-brand-primary rounded-xl flex items-center justify-center text-white font-bold text-xl font-display shadow-lg shadow-brand-primary/20">
              S
            </div>
          )}
          <span class="font-display text-2xl tracking-tight text-white">{general.brandName} <span class="text-brand-primary">{general.brandHighlight}</span></span>
        </div>
        <p class="text-gray-400 mb-8 leading-relaxed font-medium">
          {footer.about}
        </p>
        <div class="flex gap-4">
          <!-- Social Icons Mapping -->
          {footer.socialLinks.map(link => (
            <a href={link.href} aria-label={link.label} class="w-12 h-12 rounded-2xl bg-white/5 border border-white/5 flex items-center justify-center hover:bg-brand-primary hover:border-brand-primary transition-all duration-500 hover:-translate-y-1">
              {link.icon === 'instagram' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              )}
              {link.icon === 'facebook' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Unidades (Pulled from StoreInfo in config) -->
      {config.storesInfo.stores.map((store, i) => (
        <div class="aos-fade-up" style={`animation-delay: ${(1 + i) * 0.1}s`}>
          <h4 class="font-display text-lg mb-6 uppercase tracking-[0.2em] text-brand-primary">{store.name}</h4>
          <ul class="space-y-4 text-gray-400 font-medium">
            <li>{store.address}</li>
            <li>{store.city}</li>
            <li><a href={`tel:${store.phone.replace(/\D/g, '')}`} class="text-white font-black hover:text-brand-primary transition-colors text-lg">{store.phone}</a></li>
          </ul>
        </div>
      ))}

      <!-- Newsletter/Contact -->
      <div class="aos-fade-up" style="animation-delay: 0.3s">
        <h4 class="font-display text-lg mb-6 uppercase tracking-[0.2em] text-brand-primary">Contato</h4>
        <ul class="space-y-4 text-gray-400 font-medium italic">
          <li><a href={`mailto:${footer.contactEmail}`} class="hover:text-white transition-colors">{footer.contactEmail}</a></li>
          <li class="not-italic mt-4 text-sm"><a href="/politicas-de-privacidade" class="text-brand-primary hover:text-white transition-colors">Políticas de Privacidade</a></li>
        </ul>
        <div class="mt-8 p-6 bg-white/5 rounded-[2rem] border border-white/10 shadow-inner">
            <span class="block text-[10px] uppercase tracking-widest font-black text-brand-primary mb-3">{footer.hoursPill}</span>
            <p class="text-sm font-bold text-white/90 mb-1">{footer.hoursLine1}</p>
            <p class="text-sm font-bold text-white/90">{footer.hoursLine2}</p>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/10 pt-10 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-gray-500 font-medium aos-fade-up">
      <p>© {year} {footer.copyright}</p>
      <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-full">
        <span>Criado por</span>
        {footer.developerLogo ? (
          <img
            src={footer.developerLogo}
            alt={footer.developer}
            class="h-4 w-auto object-contain opacity-60 hover:opacity-100 transition-opacity duration-300"
          />
        ) : (
          <span class="text-white font-black tracking-widest text-xs uppercase">{footer.developer}</span>
        )}
      </div>
    </div>
  </div>
</footer>
