---
// src/components/CookieBanner.astro
---

<div id="cookie-banner" class="fixed bottom-0 inset-x-0 z-50 transform translate-y-full transition-transform duration-500 ease-out bg-white border-t border-gray-100 shadow-[0_-10px_40px_rgba(0,0,0,0.1)] px-6 py-5 md:py-6 flex flex-col md:flex-row items-center justify-between gap-4 md:gap-8 rounded-t-3xl md:rounded-none">
  <div class="flex-1 max-w-4xl">
    <p class="text-sm md:text-base text-gray-600 font-medium leading-relaxed">
      Nós usamos cookies para melhorar a sua experiência em nosso site. Ao continuar navegando, você concorda com a nossa 
      <a href="/politicas-de-privacidade" class="text-brand-primary hover:text-brand-primary/80 font-bold underline underline-offset-2">Política de Privacidade</a>.
    </p>
  </div>
  <div class="flex items-center gap-3 w-full md:w-auto shrink-0">
    <button id="cookie-accept" class="w-full md:w-auto px-8 py-3 bg-brand-primary hover:bg-brand-primary/90 text-white font-bold text-sm uppercase tracking-widest rounded-full transition-colors">
      Entendi e Aceito
    </button>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-accept');
    
    // Mostra o banner se o cookie não estiver setado
    if (banner && !localStorage.getItem('skina_cookies_accepted')) {
      // Pequeno delay para a animação de entrada ficar elegante
      setTimeout(() => {
        banner.classList.remove('translate-y-full');
      }, 1000);
    }

    if (acceptBtn && banner) {
      acceptBtn.addEventListener('click', () => {
        // Salva aceitação
        localStorage.setItem('skina_cookies_accepted', 'true');
        // Esconde banner
        banner.classList.add('translate-y-full');
        setTimeout(() => {
          banner.style.display = 'none';
        }, 500);
      });
    }
  });
</script>
