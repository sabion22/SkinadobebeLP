---
import { config } from '../config';
const { general, header } = config;

const whatsappLink = `https://wa.me/${general.whatsappNumber}?text=${encodeURIComponent(general.whatsappDefaultMessage)}`;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 w-full transition-all duration-500 bg-white/70 backdrop-blur-xl border-b border-white/40 shadow-[0_4px_30px_rgba(0,0,0,0.03)]">
  <div class="container mx-auto px-6 md:px-12 py-3 md:py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 md:gap-4 group">
      {general.logoSrc ? (
        <img src={general.logoSrc} alt={general.brandName} class={`${general.logoWidth} object-contain transition-transform duration-300 group-hover:scale-105`} />
      ) : (
        <div class="w-10 h-10 md:w-12 md:h-12 bg-gradient-to-br from-brand-primary to-brand-primary/80 rounded-2xl flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-brand-primary/30 group-hover:rotate-6 transition-transform duration-300">S</div>
      )}
      <div class="flex flex-col">
        <span class="font-display text-lg sm:text-xl md:text-2xl tracking-tight text-gray-900 leading-none">
          {general.brandName} <span class="text-brand-primary">{general.brandHighlight}</span>
        </span>
        <span class="text-[8px] sm:text-[9px] md:text-[10px] uppercase tracking-[0.2em] font-bold text-gray-500 mt-0.5">{general.brandSubtitle}</span>
      </div>
    </a>

    <!-- Navigation -->
    <nav class="hidden lg:flex items-center gap-8 xl:gap-10" aria-label="Navegação principal">
      {header.links.map(link => (
        <a
          href={link.href}
          class="nav-link text-xs font-black text-gray-500 hover:text-brand-primary transition-colors tracking-[0.15em] uppercase relative after:absolute after:bottom-[-3px] after:left-0 after:w-0 after:h-[2px] after:bg-brand-primary after:transition-all after:duration-300 hover:after:w-full"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-3 shrink-0">
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-whatsapp py-2 px-3 md:py-2.5 md:px-5 text-[11px] md:text-xs !rounded-xl shadow-md"
        aria-label="Fale conosco pelo WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.81 11.81 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413z"/></svg>
        <span class="font-black tracking-wide hidden sm:inline">{header.ctaText}</span>
        <span class="font-black tracking-wide sm:hidden">FALAR</span>
      </a>
    </div>
  </div>
</header>

<style>
  /* Header ao rolar — perde um pouco de transparência para leitura melhor */
  #site-header.scrolled {
    background: rgba(255, 255, 255, 0.95);
    border-bottom-color: rgba(0, 0, 0, 0.05);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    function onScroll() {
      if (window.scrollY > 40) {
        header!.classList.add('scrolled');
      } else {
        header!.classList.remove('scrolled');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
