---
import { config } from '../config';

const { hero, general } = config;

const whatsappLink = `https://wa.me/${general.whatsappNumber}?text=${encodeURIComponent(hero.cta1Message)}`;
---

<!-- HERO SECTION — 100vh Static Impact Banner -->
<section id="hero" class="relative w-full min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image — Full Screen Cinematic -->
  <img 
    src={hero.backgroundImage} 
    alt="Interior premium da loja"
    class="absolute inset-0 w-full h-full object-cover scale-105"
    loading="eager"
    fetchpriority="high"
  />
  
  <!-- Cinematic Vignette Overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/40 to-gray-900/20"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-gray-900/30 via-transparent to-gray-900/30"></div>
  
  <!-- Hero Content -->
  <div class="relative z-10 container mx-auto px-6 md:px-12 text-center lg:text-left flex flex-col items-center lg:items-start pt-20">
    <div class="max-w-5xl">
      <!-- Tag line -->
      <span class="inline-flex items-center gap-2 px-5 py-2.5 mb-8 text-[11px] font-black tracking-[0.25em] text-white uppercase bg-white/10 backdrop-blur-md rounded-full border border-white/20">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-primary"></span>
        </span>
        {hero.pillText}
      </span>
      
      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] xl:text-[6.5rem] font-display text-white mb-6 md:mb-8 leading-[1.05] tracking-tight drop-shadow-2xl">
        {hero.headlineLine1} <br class="hidden lg:block" />
        {hero.headlineLine2} <span class="text-brand-primary italic">{hero.headlineHighlight}</span><br class="hidden lg:block" /> {hero.headlineLine3}
      </h1>
      
      <!-- Subheadline -->
      <p class="text-white/80 text-lg sm:text-xl md:text-2xl max-w-2xl lg:mx-0 mx-auto leading-relaxed font-medium mb-10 md:mb-12 drop-shadow-lg">
        {hero.subheadline}
      </p>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
        <a 
          href={whatsappLink} 
          target="_blank"
          class="btn-whatsapp text-base sm:text-lg px-8 md:px-10 py-4 md:py-5 animate-pulse-glow w-full sm:w-auto"
        >
          <!-- Better Whatsapp Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.81 11.81 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413z"/>
          </svg>
          <span class="font-black text-sm md:text-base tracking-wide">{hero.cta1Text}</span>
        </a>
        <a href={hero.cta2Href} class="text-white/70 hover:text-white text-xs md:text-sm font-bold uppercase tracking-widest flex items-center justify-center gap-2 group transition-colors duration-300 w-full sm:w-auto py-4">
          <span>{hero.cta2Text}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
