---
import { config } from '../config';

const { hero, general, storesInfo } = config;

const whatsappLink = `https://wa.me/${general.whatsappNumber}?text=${encodeURIComponent(hero.cta1Message)}`;

const bgImage = hero.backgroundImage;

// Imagem decorativa do lado direito — usa a primeira foto de loja disponível
// Para trocar: edite hero.featureImage no config.ts ou coloque em /public/images/
const featureImage = hero.featureImage || storesInfo.stores[0].image;
---

<!-- HERO SECTION — Cinematic Split Layout -->
<section
  id="hero"
  class="hero-section relative w-full min-h-screen flex items-center overflow-hidden"
>
  <!-- Background Image — Full Screen Cinematic -->
  <img
    src={bgImage}
    alt="Interior premium da Skina do Bebê"
    class="hero-bg absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />

  <!-- Cinematic Overlays -->
  <div class="absolute inset-0 bg-gradient-to-t from-gray-950/92 via-gray-900/55 to-gray-900/25"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-gray-950/80 via-gray-900/35 to-transparent"></div>

  <!-- Layout principal -->
  <div class="hero-content relative z-10 w-full container mx-auto px-6 md:px-12 lg:px-16 xl:px-20 pt-24 pb-16 md:pt-28 md:pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 items-center min-h-[calc(100vh-6rem)] gap-0 lg:gap-16 xl:gap-20">

      <!-- LEFT COLUMN — Conteúdo Principal -->
      <div class="hero-text flex flex-col items-center lg:items-start text-center lg:text-left">

        <!-- Pill / Tag -->
        <span class="hero-pill inline-flex items-center gap-2 px-5 py-2.5 mb-7 md:mb-8 text-[10px] md:text-[11px] font-black tracking-[0.22em] text-white uppercase bg-white/10 backdrop-blur-md rounded-full border border-white/20">
          <span class="relative flex h-2 w-2 shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-primary"></span>
          </span>
          {hero.pillText}
        </span>

        <!-- Headline -->
        <h1 class="hero-headline text-[2.6rem] sm:text-5xl md:text-6xl lg:text-[3.8rem] xl:text-[4.8rem] 2xl:text-[5.5rem] font-display text-white mb-5 md:mb-6 leading-[1.07] tracking-tight drop-shadow-2xl">
          {hero.headlineLine1}<br class="hidden sm:block" />
          {hero.headlineLine2} <em class="text-brand-primary not-italic">{hero.headlineHighlight}</em><br class="hidden sm:block" />
          {hero.headlineLine3}
        </h1>

        <!-- Subheadline -->
        <p class="hero-sub text-white/75 text-base sm:text-lg md:text-xl max-w-md lg:max-w-lg lg:mx-0 mx-auto leading-relaxed font-medium mb-8 md:mb-10 drop-shadow-lg">
          {hero.subheadline}
        </p>

        <!-- CTA único — Fale Conosco -->
        <div class="hero-ctas w-full lg:w-auto">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            id="hero-cta-whatsapp"
            class="hero-cta-primary btn-whatsapp w-full sm:w-auto inline-flex text-base md:text-lg px-10 md:px-14 py-4 md:py-5 animate-pulse-glow font-black tracking-wide"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="shrink-0" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.81 11.81 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413z"/>
            </svg>
            <span>{hero.cta1Text}</span>
          </a>
        </div>

        <!-- Trust Badges -->
        <div class="hero-trust flex flex-wrap items-center justify-center lg:justify-start gap-x-5 gap-y-2 mt-8 md:mt-10">
          <span class="trust-badge inline-flex items-center gap-1.5 text-white/55 text-[11px] font-semibold tracking-wide">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-brand-primary shrink-0" aria-hidden="true"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
            Loja física verificada
          </span>
          <span class="trust-badge inline-flex items-center gap-1.5 text-white/55 text-[11px] font-semibold tracking-wide">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary shrink-0" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            +10 anos de tradição
          </span>
          <span class="trust-badge inline-flex items-center gap-1.5 text-white/55 text-[11px] font-semibold tracking-wide">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary shrink-0" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            5mil+ famílias atendidas
          </span>
        </div>
      </div>

      <!-- RIGHT COLUMN — Frame de imagem estilizado (desktop only) -->
      <div class="hero-visual hidden lg:flex items-center justify-center relative" aria-hidden="true">

        <!-- Glow ambiente atrás do frame -->
        <div class="absolute inset-0 bg-brand-primary/8 blur-[80px] rounded-full scale-75"></div>

        <!-- Frame wrapper com rotação e sombra -->
        <div class="hero-img-frame relative w-full max-w-[420px] xl:max-w-[480px]">

          <!-- Anel decorativo externo -->
          <div class="absolute -inset-3 rounded-[2.8rem] border border-white/10 rotate-3"></div>
          <div class="absolute -inset-6 rounded-[3.2rem] border border-white/5 -rotate-2"></div>

          <!-- Container da imagem principal -->
          <div class="relative overflow-hidden rounded-[2.5rem] shadow-[0_40px_100px_rgba(0,0,0,0.6)] border border-white/15 -rotate-2 hover:rotate-0 transition-transform duration-700">
            <img
              src={featureImage}
              alt="Skina do Bebê — fachada da loja"
              class="w-full h-[420px] xl:h-[480px] object-cover scale-[1.04] hover:scale-100 transition-transform duration-700"
              loading="eager"
            />
            <!-- Overlay gradiente suave na imagem -->
            <div class="absolute inset-0 bg-gradient-to-t from-gray-950/50 via-transparent to-gray-900/20"></div>
            <div class="absolute inset-0 bg-gradient-to-br from-brand-primary/10 via-transparent to-transparent"></div>
          </div>

          <!-- Badge flutuante sobre a imagem — clicável para seção de lojas -->
          <a href="#historia" class="absolute -bottom-4 -left-6 bg-white/95 backdrop-blur-sm rounded-2xl px-5 py-3 shadow-2xl border border-white/20 rotate-1 hover:rotate-0 hover:shadow-brand-primary/20 hover:-translate-y-1 transition-all duration-300 group">
            <div class="flex items-center gap-3">
              <span class="w-9 h-9 bg-brand-primary/10 group-hover:bg-brand-primary/20 rounded-xl flex items-center justify-center shrink-0 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <div class="flex flex-col leading-tight">
                <span class="text-[10px] font-black uppercase tracking-widest text-brand-primary">2 unidades</span>
                <span class="text-xs font-bold text-gray-700">Piracicaba / SP</span>
              </div>
            </div>
          </a>

          <!-- Badge de anos no canto superior direito -->
          <div class="absolute -top-4 -right-4 w-16 h-16 xl:w-18 xl:h-18 bg-brand-primary rounded-full flex flex-col items-center justify-center shadow-xl shadow-brand-primary/40 -rotate-12 border-4 border-white/20">
            <span class="text-white font-black text-[13px] leading-none">10+</span>
            <span class="text-white/80 font-bold text-[8px] uppercase tracking-wide leading-none">anos</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Indicador de scroll -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 text-white/35 animate-float-down" aria-hidden="true">
    <span class="text-[9px] uppercase tracking-[0.3em] font-bold">Desça</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
  </div>
</section>

<style>
  /* Zoom suave na imagem de fundo ao carregar */
  .hero-bg {
    transform-origin: center center;
    animation: hero-bg-zoom 12s ease-out forwards;
  }
  @keyframes hero-bg-zoom {
    from { transform: scale(1.08); }
    to   { transform: scale(1.0); }
  }

  /* Animações de entrada sequenciais */
  .hero-pill {
    animation: hero-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  .hero-headline {
    animation: hero-fade-up 0.75s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }
  .hero-sub {
    animation: hero-fade-up 0.75s cubic-bezier(0.16, 1, 0.3, 1) 0.35s both;
  }
  .hero-ctas {
    animation: hero-fade-up 0.75s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
  }
  .hero-trust {
    animation: hero-fade-up 0.75s cubic-bezier(0.16, 1, 0.3, 1) 0.65s both;
  }
  .hero-img-frame {
    animation: hero-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Ajuste mobile — header fixo */
  @media (max-width: 767px) {
    .hero-section {
      min-height: 100dvh;
    }
    .hero-content {
      padding-top: 5.5rem;
    }
  }
</style>
